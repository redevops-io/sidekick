# Environment for sidekick's `selfhosted` backend (local vLLM / llama.cpp on the evo-x2 box).
# Copy to .env and `source` it, or export these before `sidekick run`.
#
# All defaults already target a local server on :8000, so in the common case you need NONE
# of these — they are here to document the knobs and to point at a remote/another box.

# Backend selector (default on this branch is already "selfhosted").
export SIDEKICK_PROVIDER=selfhosted

# Local OpenAI-compatible endpoint. Point at another host if vLLM/llama.cpp runs elsewhere.
export VLLM_BASE_URL=http://localhost:8000/v1
# Alias also honored (takes precedence): SIDEKICK_AGENT_BASE_URL

# Served model name — must match --served-model-name (vLLM) / --alias (llama.cpp).
export VLLM_MODEL=Qwen3.5-122B-A10B

# Local servers are keyless; leave as EMPTY unless you front the server with an auth proxy.
export VLLM_API_KEY=EMPTY

# Sampling temperature for the agentic loop. Low = steadier merges/refactors.
export VLLM_TEMPERATURE=0.2

# Optional run-state dir override (default: .sidekick-selfhosted in the target repo).
# export SIDEKICK_STATE_DIR=.sidekick-selfhosted
